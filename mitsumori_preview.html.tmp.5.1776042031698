<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>見積書プレビュー</title>
<style>
:root{--navy:#1e2d40;--gold:#c8a96e;--beige:#eeebe5;--border:#ddd;--bg:#f5f4f0;--white:#fff;--text:#111;--sub:#666;--red:#c0392b;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:"Meiryo","Yu Gothic",sans-serif;background:var(--bg);height:100vh;display:flex;flex-direction:column;overflow:hidden;}
.topbar{background:var(--navy);color:#fff;padding:0 16px;height:48px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.topbar-title{font-size:14px;font-weight:500;letter-spacing:0.05em;}
.topbar-actions{display:flex;gap:8px;align-items:center;}
.btn{padding:6px 16px;border-radius:4px;font-size:12px;cursor:pointer;border:none;font-family:inherit;}
.btn-outline{background:transparent;border:1px solid rgba(255,255,255,0.4);color:#fff;font-size:11px;}
.btn-outline:hover{background:rgba(255,255,255,0.1);}
.btn-gold{background:var(--gold);color:var(--navy);font-weight:700;}
.btn-gold:hover{background:#d4b97e;}
.mode-label{font-size:11px;color:rgba(255,255,255,0.6);margin-right:4px;}
.mode-select{background:#2a3f58;color:#fff;border:1px solid rgba(255,255,255,0.3);border-radius:4px;padding:4px 8px;font-size:11px;cursor:pointer;font-family:inherit;}
.main{display:flex;flex:1;overflow:hidden;}
.resizer{width:5px;background:var(--border);cursor:col-resize;flex-shrink:0;transition:background 0.15s;}
.resizer:hover,.resizer.dragging{background:var(--navy);}
.editor{width:520px;min-width:320px;max-width:70vw;background:var(--white);display:flex;flex-direction:column;overflow:hidden;flex-shrink:0;}
.editor-head{padding:10px 14px;border-bottom:1px solid var(--border);background:var(--beige);display:flex;align-items:center;justify-content:space-between;}
.editor-head h2{font-size:12px;color:var(--navy);font-weight:700;letter-spacing:0.06em;}
.editor-body{flex:1;overflow-y:auto;padding:12px 14px;}
.fgroup{margin-bottom:10px;}
.fgroup label{display:block;font-size:11px;color:var(--sub);margin-bottom:3px;font-weight:500;}
.fgroup input,.fgroup select,.fgroup textarea{width:100%;border:1px solid var(--border);border-radius:3px;padding:5px 8px;font-size:12px;font-family:inherit;color:var(--text);background:#fff;}
.fgroup input:focus,.fgroup select:focus,.fgroup textarea:focus{outline:none;border-color:var(--navy);}
.fgroup textarea{resize:vertical;min-height:48px;}
.fgroup-row{display:flex;gap:8px;}
.fgroup-row .fgroup{flex:1;}
.section-sep{border:none;border-top:1px solid var(--border);margin:12px 0 8px;}
.section-label{font-size:11px;font-weight:700;color:var(--navy);letter-spacing:0.06em;margin-bottom:6px;}
/* フラット明細テーブル */
.items-wrap{overflow-x:auto;}
.items-table{width:100%;min-width:500px;border-collapse:collapse;font-size:11px;table-layout:fixed;}
.items-table th{background:var(--navy);color:#fff;padding:5px 5px;font-weight:500;white-space:nowrap;}
.items-table td{border-bottom:1px solid #eee;padding:6px 2px;vertical-align:middle;}
.items-table td input{width:100%;border:1px solid transparent;border-radius:2px;padding:3px 4px;font-size:11px;font-family:inherit;background:transparent;min-width:0;color:#111;}
.items-table td input[type=number]{-moz-appearance:textfield;}
.items-table td input[type=number]::-webkit-inner-spin-button,
.items-table td input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none;margin:0;}
.items-table td input:focus{border-color:var(--navy);background:#fff;outline:none;}
.items-table td input.r{text-align:right;}
.col-drag{width:18px;padding:0!important;}
.col-name{width:28%;}
.col-qty{width:9%;}
.col-unit{width:8%;}
.col-price{width:13%;}
.col-amt{width:13%;}
.col-note{width:21%;}
.col-del{width:6%;}
/* 大項目明細テーブル */
.groups-wrap{display:flex;flex-direction:column;gap:8px;}
.group-block{border:1px solid var(--border);border-radius:4px;overflow:hidden;}
.group-header{display:flex;align-items:center;background:#e8ecf0;padding:5px 8px;gap:6px;}
.group-header input{flex:1;border:none;background:transparent;font-size:12px;font-weight:700;color:var(--navy);font-family:inherit;outline:none;}
.group-header input:focus{background:#fff;border-radius:2px;padding:1px 4px;}
.group-del-btn{background:none;border:none;cursor:pointer;color:#ccc;font-size:12px;padding:2px 4px;}
.group-del-btn:hover{color:var(--red);}
.group-items-table{width:100%;min-width:400px;border-collapse:collapse;font-size:11px;table-layout:fixed;}
.group-items-table th{background:#f0f2f4;color:var(--navy);padding:4px 5px;font-weight:500;font-size:10px;border-bottom:1px solid var(--border);}
.group-items-table td{border-bottom:1px solid #eee;padding:9px 2px;height:52px;vertical-align:middle;}
.group-items-table td input{width:100%;border:1px solid transparent;border-radius:2px;padding:3px 4px;font-size:11px;font-family:inherit;background:transparent;min-width:0;color:#111;}
.group-items-table td input[type=number]{-moz-appearance:textfield;}
.group-items-table td input[type=number]::-webkit-inner-spin-button,
.group-items-table td input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none;margin:0;}
.group-items-table td input:focus{border-color:var(--navy);background:#fff;outline:none;}
.group-items-table td input.r{text-align:right;}
.gcol-drag{width:18px;padding:0!important;}
.gcol-name{width:30%;}
.gcol-qty{width:10%;}
.gcol-unit{width:9%;}
.gcol-price{width:14%;}
.gcol-amt{width:14%;}
.gcol-note{width:15%;}
.gcol-del{width:6%;}
.group-subtotal{text-align:right;padding:4px 8px;font-size:11px;color:var(--sub);background:#f8f8f6;border-top:1px solid var(--border);}
.add-item-btn{width:100%;padding:4px;border:none;background:#f0f2f4;font-size:11px;color:var(--sub);cursor:pointer;font-family:inherit;text-align:left;padding-left:10px;}
.add-item-btn:hover{color:var(--navy);background:#e8ecf0;}
.add-row-btn{margin-top:6px;width:100%;padding:5px;border:1px dashed var(--border);border-radius:3px;background:transparent;font-size:11px;color:var(--sub);cursor:pointer;font-family:inherit;}
.add-row-btn:hover{border-color:var(--navy);color:var(--navy);}
.del-btn{background:none;border:none;cursor:pointer;color:#ccc;font-size:12px;padding:2px 3px;border-radius:2px;}
.del-btn:hover{color:var(--red);background:#fff0f0;}
.drag-handle{cursor:grab;color:#ccc;font-size:13px;padding:2px 3px;user-select:none;line-height:1;}
.drag-handle:hover{color:var(--navy);}
.drag-handle:active{cursor:grabbing;}
tr.drag-over td{border-top:2px solid var(--navy)!important;}
tr.dragging{opacity:0.4;}
.pb-btn{background:none;border:1px solid #ddd;cursor:pointer;color:#bbb;font-size:9px;padding:2px 4px;border-radius:2px;white-space:nowrap;font-family:inherit;}
.pb-btn:hover{border-color:var(--navy);color:var(--navy);}
.pb-btn.on{background:var(--navy);border-color:var(--navy);color:#fff;}
.pb-row-mark td{border-top:2px dashed var(--navy)!important;position:relative;}
.pb-row-mark td:first-child::before{content:"── 改ページ ──";position:absolute;top:-10px;left:0;font-size:9px;color:var(--navy);background:#fff;padding:0 4px;letter-spacing:0.05em;}
.total-box{background:var(--beige);border-radius:4px;padding:8px 12px;margin-top:10px;font-size:12px;}
.total-row{display:flex;justify-content:space-between;padding:2px 0;color:var(--sub);}
.total-row.final{font-weight:700;font-size:14px;color:var(--navy);border-top:1px solid var(--border);padding-top:5px;margin-top:3px;}
.preview{flex:1;overflow:auto;padding:20px;background:#ccc;}
.preview-inner{transform-origin:top left;}
.doc-page{width:210mm;min-height:297mm;margin:0 auto;background:#fff;padding:13mm 15mm;font-family:"Meiryo","Hiragino Kaku Gothic ProN","Yu Gothic",sans-serif;font-size:14px;line-height:1.65;color:#111;box-shadow:0 2px 16px rgba(0,0,0,.18);}
/* ── ひな形CSS プレビュー内に適用 ── */
.doc-page :root{--text:#111111;--text-sub:#444444;--white:#ffffff;--band:#555555;--band-dark:#444444;--band-mid:#666666;--even:#f4f4f4;--subtotal-bg:#e8e8e8;--border:#bbbbbb;--border-dark:#888888;--light:#f8f8f8;}
.doc-page .header{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:3px solid #111;padding-bottom:8px;margin-bottom:10px;}
.doc-page .header-left{position:relative;display:inline-block;}
.doc-page .company-name{font-family:"Yu Mincho","Hiragino Mincho ProN",serif;font-size:22px;font-weight:700;color:#111;letter-spacing:0.06em;line-height:1.3;}
.doc-page .company-name .co-prefix{font-size:15px;font-weight:400;letter-spacing:0.1em;}
.doc-page .company-info{font-size:11.5px;color:#444;margin-top:5px;line-height:1.9;}
.doc-page .kakuin{width:64px;height:64px;position:absolute;top:6px;right:-28px;}
.doc-page .doc-title{font-family:"Yu Mincho","Hiragino Mincho ProN",serif;font-size:28px;font-weight:700;color:#111;letter-spacing:0.18em;text-align:right;}
.doc-page .doc-meta{font-size:11.5px;color:#444;text-align:right;margin-top:6px;line-height:2;}
.doc-page .info-section{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;gap:16px;}
.doc-page .info-left{flex:1;display:flex;flex-direction:column;gap:8px;}
.doc-page .client-name{font-family:"Yu Mincho","Hiragino Mincho ProN",serif;font-size:21px;font-weight:600;color:#111;border-bottom:2px solid #111;padding-bottom:4px;}
.doc-page .summary-box{background:#444!important;color:#fff!important;padding:12px 22px;border-radius:3px;text-align:right;flex-shrink:0;}
.doc-page .summary-box .s-label{font-size:11px;color:#e0e0e0!important;letter-spacing:0.08em;}
.doc-page .summary-box .total-amount{font-family:"Yu Mincho","Hiragino Mincho ProN",serif;font-size:26px;font-weight:700;color:#fff!important;margin-top:2px;letter-spacing:0.04em;}
.doc-page .summary-box .tax-note{font-size:11px;color:#e0e0e0!important;margin-top:3px;}
.doc-page .project-band{background:#555!important;border-left:5px solid #111;padding:6px 14px;margin-bottom:6px;font-size:11.5px;color:#fff!important;display:inline-flex;flex-direction:column;gap:3px;align-self:flex-start;}
.doc-page .band-label{color:#ddd!important;margin-right:4px;}
.doc-page .section-title{font-family:"Yu Mincho","Hiragino Mincho ProN",serif;font-size:13px;font-weight:600;color:#111;border-bottom:2px solid #111;padding-bottom:3px;margin-bottom:6px;letter-spacing:0.08em;}
.doc-page .estimate-table{width:100%;border-collapse:collapse;font-size:12px;margin-bottom:4px;border:1px solid #888;}
.doc-page .estimate-table thead th{background:#555!important;color:#fff!important;padding:6px 8px;font-weight:700;font-size:11.5px;letter-spacing:0.05em;border-right:1px solid #666;}
.doc-page .estimate-table thead th:first-child{text-align:left;}
.doc-page .estimate-table thead th:not(:first-child){text-align:right;}
.doc-page .estimate-table tbody tr{border-bottom:1px solid #bbb;}
.doc-page .estimate-table tbody tr:nth-child(even){background:#f4f4f4!important;}
.doc-page .estimate-table tbody td{padding:9px 10px;vertical-align:middle;color:#111;border-right:1px solid #bbb;}
.doc-page .estimate-table tbody td:first-child{text-align:left;}
.doc-page .estimate-table tbody td:not(:first-child){text-align:right;}
.doc-page .estimate-table .subtotal-row td{background:#e8e8e8!important;font-weight:700;font-size:13px;}
.doc-page .estimate-table .section-header td{background:#444!important;color:#fff!important;font-weight:700;font-size:11.5px;padding:4px 8px;}
.doc-page .bottom-section{display:flex;gap:14px;align-items:flex-start;margin-top:10px;margin-bottom:10px;}
.doc-page .note-box{flex:1;border:1px solid #888;border-radius:3px;padding:8px 12px;background:#f8f8f8;font-size:11px;color:#444;line-height:1.8;min-height:80px;}
.doc-page .note-title{font-size:11.5px;font-weight:700;color:#111;margin-bottom:4px;letter-spacing:0.06em;border-bottom:1px solid #bbb;padding-bottom:4px;}
.doc-page .totals-wrap{flex-shrink:0;}
.doc-page .totals-table{width:300px;border-collapse:collapse;font-size:12px;border:1px solid #888;}
.doc-page .totals-table td{padding:5px 12px;border-bottom:1px solid #bbb;color:#111;}
.doc-page .totals-table td:last-child{text-align:right;}
.doc-page .totals-table .t-subtotal td{background:#e8e8e8!important;font-weight:600;}
.doc-page .tota